                        <img class="article-cover" src="https://fdnd-agency.directus.app/assets/{{ story.cover }}"
                            alt="">
                        <div class="article-card-content">
                            <time class="article-date">{{ story.date | date: "%d-%m-%Y" }}</time>
                            <h3 class="article-title">{{ story.title }}</h3>
                        </div>
                    </article>
                </a>
                {% endfor %}
            </div>
        </section>
        {% endif %}

        {% comment %} Oost {% endcomment %}
        {% assign oost_stories = stories | where: "district", "oost" %}
        {% if oost_stories.size > 0 %}
        <section class="home-articles">
            <div class="home-district-top">
                <h2>Oost</h2>
                <a href="/oost">Alles bekijken →</a>
            </div>
            <div class="district-articles oost">
                {% for story in oost_stories %}
                <a href="/{{ story.district }}/{{ story.id }}" class="single-article-link">
                    <article class="single-article oost">
                        <img class="article-cover" src="https://fdnd-agency.directus.app/assets/{{ story.cover }}"
                            alt="">
                        <div class="article-card-content">
                            <time class="article-date">{{ story.date | date: "%d-%m-%Y" }}</time>
                            <h3 class="article-title">{{ story.title }}</h3>
                        </div>
                    </article>
                </a>
                {% endfor %}
            </div>
        </section>
        {% endif %}

    </section>

</main>

{% render 'partials/foot.liquid' %}