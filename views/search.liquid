                        <img class="article-cover" src="https://fdnd-agency.directus.app/assets/{{ story.cover }}"
                            alt="">
                        <div class="article-card-content">
                            <time class="article-date">{{ story.date | date: "%d-%m-%Y" }}</time>
                            <h3 class="article-title">{{ story.title }}</h3>
                        </div>
                    </article>
                </a>
                {% endfor %}
            </div>
        </section>
        {% endif %}

        {% comment %} Zuidoost {% endcomment %}
        {% assign zuidoost_stories = stories | where: "district", "zuidoost" %}
        {% if zuidoost_stories.size > 0 %}
        <section class="home-articles">
            <div class="home-district-top">
                <h2>Zuidoost</h2>
                <a href="/zuidoost">Alles bekijken →</a>
            </div>
            <div class="district-articles zuidoost">
                {% for story in zuidoost_stories %}
