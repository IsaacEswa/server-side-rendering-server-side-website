{% render 'partials/head.liquid' %}

<main>

    <section class="main-content">

        <h2 class="search-result">Zoekresultaten voor "{{ search }}"</h2>

        {% comment %} Algemeen {% endcomment %}
        {% assign algemeen_stories = stories | where: "district", "algemeen" %}
        {% if algemeen_stories.size > 0 %}
        <section class="home-articles">
            <div class="home-district-top">
                <h2>Algemeen</h2>
                <a href="/algemeen">Alles bekijken →</a>
            </div>
            <div class="district-articles algemeen">
                {% for story in algemeen_stories %}
                <a href="/{{ story.district }}/{{ story.id }}" class="single-article-link">
                    <article class="single-article algemeen">
                        <img class="article-cover" src="https://fdnd-agency.directus.app/assets/{{ story.cover }}"
                            alt="">
                        <div class="article-card-content">
                            <time class="article-date">{{ story.date | date: "%d-%m-%Y" }}</time>
                            <h3 class="article-title">{{ story.title }}</h3>
                        </div>
                    </article>
                </a>
                {% endfor %}
            </div>
        </section>
        {% endif %}

        {% comment %} Nieuw-West {% endcomment %}
        {% assign nieuwwest_stories = stories | where: "district", "nieuw-west" %}
        {% if nieuwwest_stories.size > 0 %}
        <section class="home-articles">
