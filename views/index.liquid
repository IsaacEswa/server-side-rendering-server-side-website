                            <h3 class="article-title">{{ story.title }}</h3>
                        </div>
                    </article>
                    </a>

                    {% assign counter = counter | plus: 1 %}
                    {% endif %}
                    {% endif %}
                    {% endfor %}
            </div>
        </section>

    </section>

